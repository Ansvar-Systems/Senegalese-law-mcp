{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "Senegal Law MCP",
  "description": "Golden contract tests for the Senegal Law MCP -- validates core tool responses against known Senegalese legislation",
  "tests": [
    {
      "id": "SN-001",
      "category": "search",
      "description": "Search for personal data protection provisions",
      "tool": "search_legislation",
      "input": { "query": "protection donnees personnelles" },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["données", "personnelles"],
        "min_results": 1
      }
    },
    {
      "id": "SN-002",
      "category": "provision",
      "description": "Retrieve Article 2 of the Data Protection Law (definitions)",
      "tool": "get_provision",
      "input": { "document_id": "loi-n-2008-12-du-25-janvier-2008-sur-la-protection-des-donnees-a-caractere-personnel", "article": "2" },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["responsable du traitement", "personne concernée"]
      }
    },
    {
      "id": "SN-003",
      "category": "search",
      "description": "Search for cybercrime provisions",
      "tool": "search_legislation",
      "input": { "query": "systeme informatique" },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["informatique"]
      }
    },
    {
      "id": "SN-004",
      "category": "provision",
      "description": "Retrieve Article 17 on international data transfers",
      "tool": "get_provision",
      "input": { "document_id": "loi-n-2008-12-du-25-janvier-2008-sur-la-protection-des-donnees-a-caractere-personnel", "article": "17" },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["transférer", "pays tiers"]
      }
    },
    {
      "id": "SN-005",
      "category": "search",
      "description": "Search for electronic signature provisions",
      "tool": "search_legislation",
      "input": { "query": "signature électronique" },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["signature"]
      }
    },
    {
      "id": "SN-006",
      "category": "sources",
      "description": "List sources returns jurisdiction info",
      "tool": "list_sources",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "SN-007",
      "category": "edge_case",
      "description": "Get provision with non-existent document ID",
      "tool": "get_provision",
      "input": { "document_id": "non-existent-law-xyz", "article": "1" },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
